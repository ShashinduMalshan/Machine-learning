   "source": [
    "import numpy as np\n",
    "mat_A = np.array([[4, 5, 3 ], [1, 2, 3], [6, 7, 5]])\n",
    "mat_B = np.array([[1, 4, 9  ], [3, 5, 8], [6, 3, 1]])\n",
    "\n",
    "mat_C = mat_A @ mat_B\n",
    "print(\"Matrix A:\\n\", mat_A)\n",
    "print(\"Matrix B:\\n\", mat_B)\n",
    "print(\"Result of A @ B:\\n\", mat_C)"
   ]
  }
